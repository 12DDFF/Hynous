# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
!nous-server/**/dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment
.env
.env.local
.env.*.local

# Data (don't commit databases)
data/*.db
data/*.sqlite
data/*.sqlite3
**/storage/**
*.db

# Logs
*.log
logs/

# Testing
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# Reflex
.web/

# OS
.DS_Store
Thumbs.db

# Temporary
tmp/
temp/
*.tmp

# v2 state storage (runtime data)
# NOTE: parent rule above uses **/storage/** (file glob, not directory exclusion)
# so these negation rules can actually re-include .gitkeep. The order matters —
# !storage/v2/ first to re-include the directory, then storage/v2/* re-excludes
# contents, then !storage/v2/.gitkeep re-includes the placeholder file.
!storage/v2/
storage/v2/*
!storage/v2/.gitkeep
